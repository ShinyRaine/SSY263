# ==========================================
# ROS 2 Colcon 编译生成的目录 (核心必填)
# ==========================================
build/
install/
log/

# ==========================================
# C/C++ 编译产生的中间文件和可执行文件
# ==========================================
*.o
*.so
*.a
*.out
*.app
*.dylib

# ==========================================
# Python 缓存文件 (ROS 2 工具链会悄悄生成)
# ==========================================
__pycache__/
*.py[cod]
*$py.class

# ==========================================
# 操作系统自动生成的垃圾文件 (特别是 Mac)
# ==========================================
.DS_Store
.AppleDouble
.LSOverride
._*

# ==========================================
# 编辑器/IDE 配置文件 (如 VS Code)
# ==========================================
.vscode/
*.swp
*.swo
